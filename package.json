{
  "name": "volary-browser",
  "version": "0.2.0-alpha",
  "description": "Security-first, context-aware web browser built on Chromium",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:*\"",
    "dev:main": "webpack --config build/config/webpack.main.config.js --mode development --watch",
    "dev:preload": "webpack --config build/config/webpack.preload.config.js --mode development --watch",
    "dev:renderer": "webpack serve --config build/config/webpack.renderer.config.js --mode development",
    "build": "tsc --build",
    "build:prod": "npm run build && webpack --config build/config/webpack.prod.config.js --mode production",
    "start": "electron dist/main.js",
    "start:prod": "npm run build:standalone && npx electron-rebuild -f -w better-sqlite3 --silent && electron dist/main.js",
    "build:standalone": "NODE_ENV=production webpack --config build/config/webpack.main.config.js --mode production && NODE_ENV=production webpack --config build/config/webpack.preload.config.js --mode production && NODE_ENV=production webpack --config build/config/webpack.renderer.config.js --mode production",
    "pack": "npm run build:standalone && electron-builder --dir",
    "dist": "npm run build:standalone && electron-builder",
    "dist:mac": "npm run build:standalone && electron-builder --mac",
    "dist:win": "npm run build:standalone && electron-builder --win",
    "dist:linux": "npm run build:standalone && electron-builder --linux",
    "pretest": "npm rebuild better-sqlite3 --silent 2>/dev/null || true",
    "test": "vitest run",
    "test:unit": "vitest run --dir __tests__/unit",
    "test:integration": "vitest run --dir __tests__/integration",
    "test:e2e": "playwright test --config tests/playwright.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'core/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,json,md}' 'core/**/*.{ts,tsx,json,md}'",
    "analyze:bundle": "webpack-bundle-analyzer dist/stats.json",
    "analyze:security": "npm audit && snyk test",
    "docs:generate": "typedoc --options typedoc.json",
    "clean": "rimraf dist coverage .webpack",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "browser",
    "privacy",
    "security",
    "chromium",
    "electron",
    "encrypted-storage",
    "context-management"
  ],
  "author": "Volary Security Team",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/volary/browser.git"
  },
  "bugs": {
    "url": "https://github.com/volary/browser/issues"
  },
  "homepage": "https://volarybrowser.com",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@noble/ciphers": "^2.1.1",
    "@noble/hashes": "^2.0.1",
    "better-sqlite3": "^12.8.0",
    "hash-wasm": "^4.12.0",
    "immer": "^11.1.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "concurrently": "^9.2.1",
    "css-loader": "^7.1.4",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "html-webpack-plugin": "^5.6.6",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.8.1",
    "process": "^0.11.10",
    "rimraf": "^6.1.3",
    "snyk": "^1.1303.2",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.4.0",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "webpack": "^5.105.4",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1"
  },
  "build": {
    "appId": "com.volary.browser",
    "productName": "Volary Browser",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.map",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "volary",
      "repo": "browser"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": true
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network",
      "maintainer": "security@volarybrowser.com"
    }
  }
}
