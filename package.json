{
  "name": "volary-browser",
  "version": "0.1.0-alpha",
  "description": "Security-first, context-aware web browser built on Chromium",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:*\"",
    "dev:main": "webpack --config build/config/webpack.main.config.js --mode development --watch",
    "dev:renderer": "webpack serve --config build/config/webpack.renderer.config.js --mode development",
    "build": "npm run build:native && npm run build:ts",
    "build:native": "cargo build --release --manifest-path=core/security/native/Cargo.toml",
    "build:ts": "tsc --build",
    "build:prod": "npm run build && webpack --config build/config/webpack.prod.config.js --mode production",
    "start": "electron dist/main.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --config tests/jest.config.js --testPathPattern=unit",
    "test:integration": "jest --config tests/jest.config.js --testPathPattern=integration",
    "test:e2e": "playwright test --config tests/playwright.config.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "npm run lint:ts && npm run lint:rust",
    "lint:ts": "eslint 'src/**/*.{ts,tsx}' 'core/**/*.{ts,tsx}' --fix",
    "lint:rust": "cargo clippy --manifest-path=core/security/native/Cargo.toml -- -D warnings",
    "format": "npm run format:ts && npm run format:rust",
    "format:ts": "prettier --write 'src/**/*.{ts,tsx,json,md}' 'core/**/*.{ts,tsx,json,md}'",
    "format:rust": "cargo fmt --manifest-path=core/security/native/Cargo.toml",
    "analyze:bundle": "webpack-bundle-analyzer dist/stats.json",
    "analyze:security": "npm audit && snyk test",
    "docs:generate": "typedoc --options typedoc.json",
    "clean": "rimraf dist coverage .webpack",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "browser",
    "privacy",
    "security",
    "chromium",
    "electron",
    "encrypted-storage",
    "context-management"
  ],
  "author": "Volary Security Team",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/volary/browser.git"
  },
  "bugs": {
    "url": "https://github.com/volary/browser/issues"
  },
  "homepage": "https://volarybrowser.com",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@noble/ciphers": "^0.5.0",
    "@noble/hashes": "^1.4.0",
    "hash-wasm": "^4.11.0",
    "electron": "^28.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0",
    "immer": "^10.0.3",
    "zod": "^3.22.4",
    "@tanstack/react-query": "^5.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "webpack-bundle-analyzer": "^4.10.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1",
    "@playwright/test": "^1.40.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.1.1",
    "concurrently": "^8.2.2",
    "rimraf": "^5.0.5",
    "electron-builder": "^24.9.1",
    "typedoc": "^0.25.4",
    "snyk": "^1.1272.0"
  },
  "optionalDependencies": {
    "@napi-rs/argon2": "^1.6.0"
  },
  "build": {
    "appId": "com.volary.browser",
    "productName": "Volary Browser",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": ["nsis", "portable"],
      "signingHashAlgorithms": ["sha256"]
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm"],
      "category": "Network",
      "maintainer": "security@volarybrowser.com"
    }
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/tests"],
    "testMatch": ["**/*.test.ts", "**/*.spec.ts"],
    "collectCoverageFrom": [
      "core/**/*.ts",
      "src/**/*.ts",
      "!**/*.d.ts",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 85,
        "lines": 85,
        "statements": 85
      }
    }
  }
}
